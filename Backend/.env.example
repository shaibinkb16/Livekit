# LiveKit Cloud (from https://cloud.livekit.io)
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# Cerebras (from https://cloud.cerebras.ai)
CEREBRAS_API_KEY=csk_xxx_your_key
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_TEMPERATURE=0.7
CEREBRAS_MAX_TOKENS=500

# Optional: Cartesia (only if NOT using LiveKit Inference)
# CARTESIA_API_KEY=your_cartesia_key

# App config
LOG_LEVEL=INFO
ENVIRONMENT=production
CORS_ORIGINS=*

# LiveKit Agents local HTTP server (health check). Change if 8081 is in use.
AGENT_HTTP_HOST=
AGENT_HTTP_PORT=8081

# Optional: enable turn detector (requires `agent --download-files` first)
USE_TURN_DETECTOR=0

